{
  "name": "biblioteca-backend",
  "version": "1.0.0",
  "description": "Backend del sistema de biblioteca - Node.js nativo + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate:up": "node-pg-migrate up --config pgmconfig.js",
    "migrate:down": "node-pg-migrate down --config pgmconfig.js",
    "migrate:create": "node-pg-migrate create --config pgmconfig.js --migration-file-language sql",
    "seed": "node scripts/run-seed.js",
    "db:setup": "npm run migrate:up && npm run seed"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.13.0"
  }
}
