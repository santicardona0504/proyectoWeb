{
  "name": "biblioteca-backend",
  "version": "1.0.0",
  "description": "Backend del sistema de biblioteca - Node.js nativo + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "build": "cd ../frontend && npm install && npm run build && mkdir -p ../backend/public && rm -rf ../backend/public/* && cp -r dist/frontend/browser/* ../backend/public/",
    "migrate": "node scripts/migrate.js",
    "migrate:create": "node-pg-migrate create --config pgmconfig.js --migration-file-language sql",
    "seed": "node scripts/run-seed.js",
    "db:setup": "node scripts/migrate.js && npm run seed",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
}
